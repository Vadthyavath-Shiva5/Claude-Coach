# Backend secret configuration (example only)
# Copy to backend/.env and set real values locally/server-side.

NODE_ENV=development
PORT=8080
ANTHROPIC_API_KEY=replace_with_real_key
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=1200
ALLOWED_ORIGIN=https://claude.ai,chrome-extension://your_extension_id
API_SHARED_KEY=replace_with_shared_key
